generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String
  avatar        String?
  bio           String?
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  conversations Conversation[]
  projects      Project[]
  notifications Notification[]
  sessions      Session[]
  fileUploads   FileUpload[]
  projectLikes  ProjectLike[]
  
  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
  @@index([userId, expiresAt]) // P0-14: 添加复合索引，便于清理过期session
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String
  messages  String   // JSON stored as string for SQLite
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([updatedAt]) // P0-14: 添加时间索引，便于排序
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  code        String?
  tags        String   // JSON array stored as string for SQLite
  stars       Int      @default(0)
  forks       Int      @default(0)
  likes       Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectLikes ProjectLike[]
  
  @@index([userId])
  @@index([isPublic])
  @@index([createdAt]) // P0-14: 添加时间索引，便于排序
}

model ProjectLike {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([userId, projectId]) // P0-6: 防止重复点赞的唯一约束
  @@index([projectId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead])
  @@index([createdAt]) // P0-14: 添加时间索引
}

model FileUpload {
  id          String   @id @default(uuid())
  userId      String
  fileName    String
  originalName String
  mimeType    String
  size        Int      // SQLite doesn't support BigInt well
  path        String
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt]) // P0-14: 添加时间索引
}
